<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>PanoramicData.ECharts.Demo</PackageId>
    <RepositoryUrl>https://github.com/panoramicdata/PanoramicData.ECharts</RepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <NeutralResourcesLanguage>en</NeutralResourcesLanguage>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\PanoramicData.ECharts.Samples\PanoramicData.ECharts.Samples.csproj" />
    <ProjectReference Include="..\PanoramicData.ECharts\PanoramicData.ECharts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="wwwroot\css\site.css" />
  </ItemGroup>
</Project>